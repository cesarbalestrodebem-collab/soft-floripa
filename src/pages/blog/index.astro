---
import Layout from '../../layouts/Layout.astro'
import { getPosts, getImageUrl } from '../../lib/payload'

const posts = await getPosts()

function formatDate(date: string) {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    timeZone: 'America/Sao_Paulo',
  }).format(new Date(date))
}
---

<Layout
  title="Blog"
  description="Dicas e informacoes sobre purificadores de agua Everest em Florianopolis."
>

  <section class="page-hero">
    <div class="container">
      <div class="section-tag">Blog</div>
      <h1>Blog Soft Floripa</h1>
      <p>Dicas e informacoes sobre purificadores de agua</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-img">
                {post.imagemCapa ? (
                  <img src={getImageUrl(post.imagemCapa)} alt={post.titulo} width="400" height="220" loading="lazy" />
                ) : (
                  <div class="blog-placeholder">📝</div>
                )}
              </div>
              <div class="blog-info">
                {post.dataPublicacao && (
                  <span class="blog-date">{formatDate(post.dataPublicacao)}</span>
                )}
                <h2>{post.titulo}</h2>
                <p>{post.resumo}</p>
                <span class="blog-link">Ler artigo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Nenhum post publicado ainda.</p>
        </div>
      )}
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 48px 0;
    text-align: center;
  }
  .section-tag {
    display: inline-block;
    font-size: 12px;
    color: #0055A5;
    background: #e6f1fb;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  .page-hero h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
  .page-hero p { font-size: 15px; color: #6b7280; }
  .section { padding: 64px 0; }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .blog-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .blog-card:hover { border-color: #0055A5; transform: translateY(-2px); }
  .blog-img {
    height: 200px;
    overflow: hidden;
    background: #e6f1fb;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .blog-img img { width: 100%; height: 100%; object-fit: cover; }
  .blog-placeholder { font-size: 48px; }
  .blog-info { padding: 20px; }
  .blog-date { font-size: 12px; color: #6b7280; display: block; margin-bottom: 8px; }
  .blog-info h2 { font-size: 16px; font-weight: 600; margin-bottom: 8px; line-height: 1.4; }
  .blog-info p { font-size: 13px; color: #6b7280; line-height: 1.5; margin-bottom: 16px; }
  .blog-link { font-size: 13px; color: #0055A5; font-weight: 500; }
  .empty-state { text-align: center; padding: 64px; color: #6b7280; }
  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
