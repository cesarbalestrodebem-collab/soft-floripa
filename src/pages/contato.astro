---
import Layout from '../layouts/Layout.astro'
import { getConfiguracoes } from '../lib/payload'

const config = await getConfiguracoes()
const whatsappLink = `https://wa.me/55${config.whatsapp1 || '48999440178'}?text=Olá! Quero mais informações sobre os purificadores Everest.`
const whatsappLink2 = `https://wa.me/55${config.whatsapp2 || '4840092170'}?text=Olá! Quero mais informações sobre os purificadores Everest.`
---

<Layout
  title="Contato"
  description="Entre em contato com a Soft Floripa. Atendemos Florianópolis e região. WhatsApp, telefone, e-mail e endereço físico."
>

  <section class="page-hero">
    <div class="container">
      <div class="section-tag">Contato</div>
      <h1>Fale com a Soft Floripa</h1>
      <p>Atendemos Florianópolis e toda a Grande Florianópolis</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contato-grid">

        <div class="contato-cards">
          <a href={whatsappLink} target="_blank" class="contato-card contato-whatsapp">
            <div class="contato-icon">💬</div>
            <div>
              <div class="contato-label">WhatsApp principal</div>
              <div class="contato-value">(48) 9 9944-0178</div>
              <div class="contato-desc">Clique para iniciar conversa</div>
            </div>
          </a>

          <a href={whatsappLink2} target="_blank" class="contato-card contato-whatsapp">
            <div class="contato-icon">💬</div>
            <div>
              <div class="contato-label">WhatsApp vendas</div>
              <div class="contato-value">(48) 4009-2170</div>
              <div class="contato-desc">Clique para iniciar conversa</div>
            </div>
          </a>

          <a href="tel:4840092250" class="contato-card">
            <div class="contato-icon">📞</div>
            <div>
              <div class="contato-label">Telefone</div>
              <div class="contato-value">(48) 4009-2250</div>
              <div class="contato-desc">Segunda a Sábado, 8h às 18h</div>
            </div>
          </a>

          <a href={`mailto:${config.email || 'contato@softfloripa.com.br'}`} class="contato-card">
            <div class="contato-icon">📧</div>
            <div>
              <div class="contato-label">E-mail</div>
              <div class="contato-value">{config.email || 'contato@softfloripa.com.br'}</div>
              <div class="contato-desc">Respondemos em até 24h</div>
            </div>
          </a>

          <div class="contato-card">
            <div class="contato-icon">📍</div>
            <div>
              <div class="contato-label">Endereço</div>
              <div class="contato-value">R. Elesbão Pinto da Luz, 718 - Sala 2</div>
              <div class="contato-desc">Jardim Atlântico, Florianópolis - SC, 88095-500</div>
            </div>
          </div>

          <div class="contato-card">
            <div class="contato-icon">🕐</div>
            <div>
              <div class="contato-label">Horário de atendimento</div>
              <div class="contato-value">Segunda a Sábado</div>
              <div class="contato-desc">Das 8h às 18h</div>
            </div>
          </div>
        </div>

        <div class="mapa-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3536.8!2d-48.5139!3d-27.6136!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjfCsDM2JzQ5LjAiUyA0OMKwMzAnNTAuMCJX!5e0!3m2!1spt-BR!2sbr!4v1234567890"
            width="100%"
            height="400"
            style="border:0; border-radius: 12px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização Soft Floripa"
          ></iframe>

          <div class="redes-sociais">
            <h3>Redes sociais</h3>
            <div class="social-btns">
              <a href={config.instagram || 'https://www.instagram.com/softfloripa/'} target="_blank" class="social-btn">
                Instagram
              </a>
              <a href={config.youtube || 'https://www.youtube.com/@softfloripa56'} target="_blank" class="social-btn">
                YouTube
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 48px 0;
    text-align: center;
  }

  .section-tag {
    display: inline-block;
    font-size: 12px;
    color: #0055A5;
    background: #e6f1fb;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .page-hero h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
  .page-hero p { font-size: 15px; color: #6b7280; }

  .section { padding: 64px 0; }

  .contato-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .contato-cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contato-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 16px 20px;
    transition: border-color 0.2s;
  }

  .contato-card:hover { border-color: #0055A5; }

  .contato-whatsapp { border-color: #dcfce7; background: #f0fdf4; }
  .contato-whatsapp:hover { border-color: #25D366; }

  .contato-icon { font-size: 24px; flex-shrink: 0; margin-top: 2px; }

  .contato-label {
    font-size: 11px;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .contato-value {
    font-size: 15px;
    font-weight: 600;
    color: #111827;
    margin-bottom: 2px;
  }

  .contato-desc { font-size: 12px; color: #6b7280; }

  .redes-sociais {
    margin-top: 20px;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px;
  }

  .redes-sociais h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .social-btns { display: flex; gap: 10px; }

  .social-btn {
    display: inline-block;
    border: 1.5px solid #0055A5;
    color: #0055A5;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .social-btn:hover {
    background: #0055A5;
    color: white;
  }

  @media (max-width: 768px) {
    .contato-grid { grid-template-columns: 1fr; }
  }
</style>