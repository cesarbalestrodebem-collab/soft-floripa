---
import Layout from '../layouts/Layout.astro'
import { getProdutos, getPosts, getConfiguracoes, getImageUrl } from '../lib/payload'

const produtos = await getProdutos()
const posts = await getPosts()
const config = await getConfiguracoes()
const whatsappLink = `https://wa.me/55${config.whatsapp1 || '48999440178'}?text=Olá! Quero mais informações sobre os purificadores Everest.`
const produtosDestaque = produtos.filter((p: any) => p.destaque).slice(0, 3)
const postsDestaque = posts.filter((p: any) => p.destaque).slice(0, 3)
---

<Layout title="Purificadores de Água Everest em Florianópolis" description="Revendedora autorizada Everest em Florianópolis. Purificadores de água com instalação gratuita, atendimento local e garantia de fábrica.">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Revendedora Autorizada Everest · Florianópolis SC</div>
      <h1>Água pura e gelada para sua casa ou empresa em <span>Florianópolis</span></h1>
      <p>Instalação gratuita, atendimento local e os melhores purificadores Everest com garantia de fábrica.</p>
      <div class="hero-btns">
        <a href="/produtos" class="btn-primary">Ver purificadores</a>
        <a href={whatsappLink} target="_blank" class="btn-outline">Falar pelo WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Benefícios -->
  <section class="benefits">
    <div class="container">
      <div class="benefits-grid">
        <div class="benefit-item">
          <div class="benefit-icon">🚚</div>
          <div class="benefit-title">Entrega local</div>
          <div class="benefit-desc">Atendemos toda Florianópolis e região</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">🔧</div>
          <div class="benefit-title">Instalação gratuita</div>
          <div class="benefit-desc">Técnico especializado sem custo adicional</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">💳</div>
          <div class="benefit-title">Até 12x no cartão</div>
          <div class="benefit-desc">Ou desconto especial no Pix</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">✅</div>
          <div class="benefit-title">Revenda autorizada</div>
          <div class="benefit-desc">Produto original com garantia Everest</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Produtos em destaque -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Produtos Everest</div>
        <h2>Purificadores em destaque</h2>
        <p>Linha completa Everest com água gelada, natural e quente para todos os ambientes</p>
      </div>
      {produtosDestaque.length > 0 ? (
        <div class="produtos-grid">
          {produtosDestaque.map((produto: any) => (
            <a href={`/produtos/${produto.slug}`} class="produto-card">
              <div class="produto-img">
                {produto.imagens?.[0]?.imagem ? (
                  <img
                    src={getImageUrl(produto.imagens[0].imagem)}
                    alt={produto.nome}
                    width="300"
                    height="300"
                    loading="lazy"
                  />
                ) : (
                  <div class="produto-placeholder">💧</div>
                )}
              </div>
              <div class="produto-info">
                <h3>{produto.nome}</h3>
                <p>{produto.descricao}</p>
                <span class="btn-card">Saiba mais</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Cadastre produtos no admin para exibi-los aqui.</p>
          <a href="/produtos" class="btn-primary" style="margin-top:16px">Ver todos os purificadores</a>
        </div>
      )}
      <div class="section-cta">
        <a href="/produtos" class="btn-primary">Ver todos os purificadores</a>
      </div>
    </div>
  </section>

  <!-- Por que Everest -->
  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Por que Everest?</div>
        <h2>Pureza, economia e qualidade</h2>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">❄️</div>
          <h3>Água realmente gelada</h3>
          <p>Sistema de compressor que garante água a até 8°C, mesmo no verão catarinense.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🛡️</div>
          <h3>Filtragem avançada</h3>
          <p>Remove cloro, impurezas, odores e sabores indesejados da água da rede.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <h3>Economia real</h3>
          <p>Elimine gastos com garrafões e garrafas PET. Água pura direto da torneira.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌱</div>
          <h3>Sustentabilidade</h3>
          <p>Reduza o descarte de plástico e contribua para um ambiente mais limpo em Floripa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  {postsDestaque.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">Blog</div>
          <h2>Últimas do blog</h2>
        </div>
        <div class="blog-grid">
          {postsDestaque.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              {post.imagemCapa && (
                <img
                  src={getImageUrl(post.imagemCapa)}
                  alt={post.titulo}
                  width="400"
                  height="200"
                  loading="lazy"
                />
              )}
              <div class="blog-info">
                <h3>{post.titulo}</h3>
                <p>{post.resumo}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="section-cta">
          <a href="/blog" class="btn-primary">Ver todos os posts</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA WhatsApp -->
  <section class="cta-whatsapp">
    <div class="container">
      <h2>Fale com um especialista</h2>
      <p>Tire suas dúvidas e escolha o purificador ideal para sua necessidade.</p>
      <a href={whatsappLink} target="_blank" class="btn-primary">Falar pelo WhatsApp agora</a>
    </div>
  </section>

</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #0055A5 0%, #003d7a 100%);
    padding: 80px 0 64px;
    text-align: center;
    color: white;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    font-size: 12px;
    padding: 4px 16px;
    border-radius: 20px;
    margin-bottom: 20px;
  }

  .hero h1 {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero h1 span { color: #7ec8f5; }

  .hero p {
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    max-width: 520px;
    margin: 0 auto 32px;
  }

  .hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .benefits {
    border-bottom: 1px solid #e5e7eb;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 16px;
    border-right: 1px solid #e5e7eb;
  }

  .benefit-item:last-child { border-right: none; }

  .benefit-icon { font-size: 24px; margin-bottom: 8px; }
  .benefit-title { font-size: 13px; font-weight: 600; color: #0055A5; margin-bottom: 4px; }
  .benefit-desc { font-size: 12px; color: #6b7280; }

  .section { padding: 64px 0; }
  .section-gray { background: #f9fafb; }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-tag {
    display: inline-block;
    font-size: 12px;
    color: #0055A5;
    background: #e6f1fb;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .section-header h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .section-header p {
    font-size: 15px;
    color: #6b7280;
  }

  .produtos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .produto-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  .produto-card:hover {
    border-color: #0055A5;
    transform: translateY(-2px);
  }

  .produto-img {
    height: 200px;
    background: #e6f1fb;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .produto-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .produto-placeholder { font-size: 64px; }

  .produto-info {
    padding: 16px;
  }

  .produto-info h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .produto-info p {
    font-size: 13px;
    color: #6b7280;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .btn-card {
    display: inline-block;
    background: #0055A5;
    color: white;
    font-size: 13px;
    padding: 8px 16px;
    border-radius: 8px;
  }

  .section-cta {
    text-align: center;
    margin-top: 32px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }

  .feature-icon { font-size: 32px; margin-bottom: 12px; }

  .feature-card h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .feature-card p {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.5;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .blog-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .blog-card:hover { border-color: #0055A5; }

  .blog-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .blog-info { padding: 16px; }

  .blog-info h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .blog-info p {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.5;
  }

  .cta-whatsapp {
    background: #0055A5;
    color: white;
    text-align: center;
    padding: 64px 0;
  }

  .cta-whatsapp h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .cta-whatsapp p {
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    margin-bottom: 24px;
  }

  .cta-whatsapp .btn-primary {
    background: white;
    color: #0055A5;
  }

  .cta-whatsapp .btn-primary:hover {
    background: #f0f7ff;
  }

  .empty-state {
    text-align: center;
    padding: 48px;
    color: #6b7280;
  }

  @media (max-width: 768px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
    .produtos-grid { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>